{
  "name": "mvps-linker",
  "displayName": "MVPS Linker",
  "description": "Enables multi-file VEX Python projects",
  "version": "1.1.0",
  "publisher": "tatedel",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "extensionDependencies": ["vexrobotics.vexcode"],
  "contributes": {
    "commands": [
      {
        "command": "mvps-linker.run",
        "title": "Run Linker",
        "category": "MVPS Linker"
      },
      {
        "command": "mvps-linker.buildAndDownload",
        "title": "Download",
        "category": "MVPS Linker"
      },
      {
        "command": "mvps-linker.createTemplate",
        "title": "Create Template",
        "category": "MVPS Linker"
      }
    ],
    "configuration": {
      "title": "MVPS Linker",
      "properties": {
        "mvps-linker.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter used by MVPS Linker (e.g. /opt/homebrew/bin/python3)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mvps-linker-sidebar",
          "title": "MVPS Linker",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "mvps-linker-sidebar": [
        {
          "type": "webview",
          "id": "mvps-linker.view",
          "name": "MVPS Linker",
          "icon": "icon.png"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}